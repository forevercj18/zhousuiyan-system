<view class="container">
  <!-- 需要登录 -->
  <view class="empty-state" wx:if="{{needLogin}}">
    <text class="empty-icon">🔐</text>
    <text class="empty-text">登录后查看您的订单</text>
    <button class="btn-primary" style="margin-top: 30rpx; font-size: 28rpx;" bindtap="doLogin">微信授权登录</button>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:elif="{{loading}}">
    <view class="loading-spinner"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{isEmpty}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
    <button class="btn-primary" style="margin-top: 30rpx; font-size: 28rpx;" bindtap="goHome">去逛逛</button>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:else>
    <view class="card order-card" wx:for="{{orders}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-no">{{item.reservation_no}}</text>
        <text class="order-status {{item.statusClass}}">{{item.status_label}}</text>
      </view>

      <view class="order-body">
        <image class="order-image" src="{{item.sku_cover_image}}" mode="aspectFill" wx:if="{{item.sku_cover_image}}" />
        <view class="order-image order-image-placeholder" wx:else>
          <text>🎂</text>
        </view>
        <view class="order-info">
          <text class="order-sku-name">{{item.sku_name}}</text>
          <text class="order-date">活动日期：{{item.event_date}}</text>
          <view class="progress-row">
            <text class="progress-label">当前进度</text>
            <text class="journey-badge {{item.journeyClass}}">{{item.journey_label}}</text>
          </view>
          <text class="progress-tip">{{item.progressText}}</text>
          <view class="order-bottom-row">
            <text class="order-qty">x{{item.quantity}}</text>
            <text class="order-deposit" wx:if="{{item.deposit_amount > 0}}">已付订金 ¥{{item.deposit_amount}}</text>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <text class="order-time">{{item.created_at}}</text>
        <text class="order-arrow">›</text>
      </view>
    </view>
  </view>
</view>
