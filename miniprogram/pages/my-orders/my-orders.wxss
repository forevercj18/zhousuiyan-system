/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.order-card {
  padding: 24rpx;
}

/* 头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.order-no {
  font-size: 24rpx;
  color: #999;
}
.order-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}
.status-pending {
  background: #fff3e0;
  color: #e65100;
}
.status-confirm {
  background: #e3f2fd;
  color: #1565c0;
}
.status-done {
  background: #e8f5e9;
  color: #2e7d32;
}
.status-cancel {
  background: #f5f5f5;
  color: #999;
}

/* 内容 */
.order-body {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}
.order-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.order-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fce4ec;
  font-size: 60rpx;
}
.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
.order-sku-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.order-date {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}
.progress-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}
.progress-label {
  font-size: 22rpx;
  color: #999;
}
.journey-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.journey-pending {
  background: #fff8e1;
  color: #ad6800;
}
.journey-warning {
  background: #fff1f0;
  color: #cf1322;
}
.journey-primary {
  background: #e6f4ff;
  color: #0958d9;
}
.journey-success {
  background: #f6ffed;
  color: #389e0d;
}
.journey-closed {
  background: #f5f5f5;
  color: #8c8c8c;
}
.progress-tip {
  font-size: 22rpx;
  color: #666;
  margin-top: 10rpx;
}
.order-bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.order-qty {
  font-size: 24rpx;
  color: #999;
}
.order-deposit {
  font-size: 24rpx;
  color: #ff6b81;
  font-weight: 500;
}

/* 底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.order-time {
  font-size: 22rpx;
  color: #ccc;
}
.order-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #ff6b81;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
