/* 状态头 */
.status-header {
  margin: 0 -24rpx;
  margin-top: -20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 20rpx;
}
.bg-pending {
  background: linear-gradient(135deg, #ff9800, #ffc107);
}
.bg-confirm {
  background: linear-gradient(135deg, #2196f3, #42a5f5);
}
.bg-done {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}
.bg-cancel {
  background: linear-gradient(135deg, #9e9e9e, #bdbdbd);
}
.status-label {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.status-tip {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
  display: block;
}

.progress-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.summary-badge {
  font-size: 24rpx;
  color: #ff6b81;
  background: #fff0f4;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
}
.summary-text {
  font-size: 24rpx;
  color: #666;
}
.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.step-item {
  display: flex;
  gap: 20rpx;
}
.step-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}
.step-done {
  background: #52c41a;
}
.step-current {
  background: #1677ff;
  box-shadow: 0 0 0 8rpx rgba(22, 119, 255, 0.15);
}
.step-pending {
  background: #d9d9d9;
}
.step-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.step-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}
.step-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 信息卡片 */
.info-card {
  padding: 24rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6b81;
}

/* 产品行 */
.product-row {
  display: flex;
  gap: 20rpx;
}
.product-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.product-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fce4ec;
  font-size: 56rpx;
}
.product-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}
.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.product-qty {
  font-size: 24rpx;
  color: #999;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}
.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}
.info-value-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.copy-btn {
  font-size: 22rpx;
  color: #ff6b81;
  padding: 4rpx 12rpx;
  border: 1rpx solid #ff6b81;
  border-radius: 6rpx;
}

/* 备注 */
.notes-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #ff6b81;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
