.search-bar { padding: 12rpx 0 20rpx; }
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}
.search-input { flex: 1; font-size: 28rpx; height: 40rpx; }
.filter-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}
.picker-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.picker-wrap {
  flex: 1;
}
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 28rpx;
  padding: 16rpx 22rpx;
  font-size: 24rpx;
  color: #555;
  border: 2rpx solid #f0f0f0;
}
.picker-arrow {
  color: #999;
  font-size: 20rpx;
}
.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #666;
  font-size: 24rpx;
  border: 2rpx solid #f0f0f0;
}
.filter-chip.active {
  color: #ff6b81;
  background: #fff0f4;
  border-color: #ffc4d0;
}
.filter-chip.active.danger {
  color: #d4380d;
  background: #fff2f0;
  border-color: #ffccc7;
}
.filter-chip.active.work {
  color: #1677ff;
  background: #eef5ff;
  border-color: #cfe2ff;
}
.filter-chip.active.blue {
  color: #0958d9;
  background: #e6f4ff;
  border-color: #b9d4ff;
}
.order-list { display: flex; flex-direction: column; gap: 18rpx; }
.order-card { padding: 24rpx; }
.order-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}
.order-no { font-size: 24rpx; color: #999; }
.order-status { font-size: 24rpx; color: #ff6b81; }
.main-line { display: block; margin-top: 16rpx; font-size: 28rpx; font-weight: 600; color: #333; }
.sub-line { display: block; margin-top: 8rpx; font-size: 24rpx; color: #666; }
.meta-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 14rpx; }
.meta-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff7e6;
  color: #d48806;
  font-size: 22rpx;
}
.meta-tag.blue {
  background: #e6f4ff;
  color: #1677ff;
}
.tool-row { display: flex; gap: 12rpx; margin-top: 16rpx; }
.mini-btn {
  margin: 0;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #cfe2ff;
  font-size: 22rpx;
}
.mini-btn.primary {
  background: #1677ff;
  color: #fff;
  border-color: #1677ff;
}
.mini-btn.subtle {
  color: #666;
  border-color: #e5e7eb;
}
.loading-spinner {
  width: 48rpx; height: 48rpx; border: 4rpx solid #eee; border-top-color: #ff6b81; border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
