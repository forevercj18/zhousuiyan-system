<view class="container">
  <!-- 产品摘要 -->
  <view class="card summary-card">
    <text class="summary-name">{{skuName}}</text>
    <view class="summary-price-row">
      <text class="price"><text class="price-symbol">¥</text><text class="price-value">{{skuPrice}}</text>/次</text>
      <text class="summary-deposit">押金 ¥{{skuDeposit}}</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="card form-card">
    <view class="form-section-title">联系方式</view>

    <view class="form-item">
      <text class="form-label">微信号 <text class="required">*</text></text>
      <input class="form-input" placeholder="客服将通过微信联系您" value="{{customerWechat}}" bindinput="onInputWechat" />
    </view>

    <view class="form-item">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <view class="phone-input-wrap">
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{customerPhone}}" bindinput="onInputPhone" />
        <button class="phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">一键获取</button>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="您的称呼" value="{{customerName}}" bindinput="onInputName" />
    </view>

    <view class="form-item">
      <text class="form-label">所在城市</text>
      <input class="form-input" placeholder="如：广州" value="{{city}}" bindinput="onInputCity" />
    </view>

    <view class="form-item form-item-textarea">
      <text class="form-label">收货地址 <text class="required">*</text></text>
      <textarea class="form-textarea" placeholder="请填写详细收货地址，如：广州市天河区xx路xx号" value="{{deliveryAddress}}" bindinput="onInputAddress" maxlength="500" />
    </view>
  </view>

  <view class="card form-card">
    <view class="form-section-title">租赁信息</view>

    <view class="form-item">
      <text class="form-label">活动日期 <text class="required">*</text></text>
      <picker mode="date" start="{{minDate}}" value="{{eventDate}}" bindchange="onDateChange">
        <view class="form-picker {{eventDate ? '' : 'placeholder'}}">
          {{eventDate || '请选择活动日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">数量</text>
      <view class="quantity-picker">
        <view class="qty-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="onQuantityMinus">−</view>
        <text class="qty-value">{{quantity}}</text>
        <view class="qty-btn {{quantity >= 10 ? 'disabled' : ''}}" bindtap="onQuantityPlus">+</view>
      </view>
    </view>

    <view class="form-item form-item-textarea">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="如有特殊需求请备注，如颜色偏好、布置要求等" value="{{notes}}" bindinput="onInputNotes" maxlength="500" />
    </view>
  </view>

  <!-- 提示 -->
  <view class="notice-card">
    <text class="notice-icon">💡</text>
    <text class="notice-text">提交后客服将通过微信与您联系确认，确认无误后再进行付款，请放心提交。</text>
  </view>

  <!-- 底部留白 -->
  <view style="height: 140rpx;"></view>
</view>

<!-- 底部提交按钮 -->
<view class="bottom-bar">
  <button class="btn-primary btn-submit {{submitting ? 'btn-disabled' : ''}}" bindtap="onSubmit" disabled="{{submitting}}">
    {{submitting ? '提交中...' : '提交意向订单'}}
  </button>
</view>
