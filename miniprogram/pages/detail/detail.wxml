<view class="container" wx:if="{{!loading && sku}}">
  <!-- 轮播图 -->
  <view class="swiper-wrap">
    <swiper class="image-swiper"
            indicator-dots="{{sku.images.length > 1}}"
            indicator-active-color="#ff6b81"
            autoplay="{{true}}"
            circular="{{true}}"
            bindchange="onSwiperChange">
      <swiper-item wx:for="{{sku.images}}" wx:key="url">
        <image class="swiper-image" src="{{item.url}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.url}}" />
      </swiper-item>
      <!-- 没有多图时显示占位 -->
      <swiper-item wx:if="{{!sku.images.length}}">
        <view class="swiper-image swiper-placeholder">
          <text style="font-size: 120rpx;">🎂</text>
        </view>
      </swiper-item>
    </swiper>
    <!-- 库存标签 -->
    <view class="detail-stock-tag tag tag-warning" wx:if="{{sku.stock_status === 'warning'}}">即将售罄</view>
    <view class="detail-stock-tag tag tag-soldout" wx:elif="{{sku.stock_status === 'soldout'}}">已售罄</view>
  </view>

  <!-- 价格信息 -->
  <view class="card price-card">
    <view class="price-row">
      <view class="price">
        <text class="price-symbol">¥</text>
        <text class="price-value" style="font-size: 48rpx;">{{sku.rental_price}}</text>
        <text class="price-label">/次租金</text>
      </view>
      <view class="deposit-info">
        <text class="deposit-label">押金 ¥{{sku.deposit}}</text>
      </view>
    </view>
    <text class="sku-title">{{sku.name}}</text>
    <view class="stock-row" wx:if="{{sku.stock_status !== 'soldout'}}">
      <text class="stock-text">剩余 {{sku.display_stock}} 套可租</text>
    </view>
  </view>

  <!-- 套餐包含 -->
  <view class="card components-card" wx:if="{{sku.components.length}}">
    <view class="section-title">套餐包含</view>
    <view class="component-list">
      <view class="component-item" wx:for="{{sku.components}}" wx:key="name">
        <view class="component-dot"></view>
        <text class="component-name">{{item.name}}</text>
        <text class="component-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
        <text class="component-qty">x{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 详细描述 -->
  <view class="card desc-card" wx:if="{{sku.description}}">
    <view class="section-title">详细说明</view>
    <text class="desc-text">{{sku.description}}</text>
  </view>

  <!-- 底部留白（给固定按钮让位） -->
  <view style="height: 140rpx;"></view>
</view>

<!-- 加载中 -->
<view class="loading-wrap" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
</view>

<!-- 底部固定按钮 -->
<view class="bottom-bar" wx:if="{{!loading && sku}}">
  <view class="bottom-bar-inner">
    <view class="bottom-price">
      <text class="price-symbol">¥</text>
      <text class="price-value">{{sku.rental_price}}</text>
    </view>
    <button class="btn-primary btn-rent {{sku.stock_status === 'soldout' ? 'btn-disabled' : ''}}"
            bindtap="goOrder">
      {{sku.stock_status === 'soldout' ? '已售罄' : '我要租'}}
    </button>
  </view>
</view>
