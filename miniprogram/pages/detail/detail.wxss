/* 轮播图 */
.swiper-wrap {
  position: relative;
  margin: 0 -24rpx;
  margin-top: -20rpx;
}
.image-swiper {
  width: 100%;
  height: 560rpx;
}
.swiper-image {
  width: 100%;
  height: 100%;
}
.swiper-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fce4ec;
}
.detail-stock-tag {
  position: absolute;
  top: 24rpx;
  left: 0;
  padding: 8rpx 24rpx 8rpx 16rpx;
  border-radius: 0 24rpx 24rpx 0;
  font-size: 24rpx;
  font-weight: 600;
}

/* 价格卡片 */
.price-card {
  padding: 28rpx 24rpx;
  margin-top: 20rpx;
}
.price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.price-label {
  font-size: 24rpx;
  color: #ff6b81;
  margin-left: 8rpx;
}
.deposit-info {
  margin-bottom: 4rpx;
}
.deposit-label {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.sku-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-top: 16rpx;
  display: block;
  line-height: 1.4;
}
.stock-row {
  margin-top: 12rpx;
}
.stock-text {
  font-size: 24rpx;
  color: #999;
}

/* 套餐包含 */
.components-card, .desc-card {
  padding: 28rpx 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6b81;
}
.component-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.component-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
}
.component-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff6b81;
  flex-shrink: 0;
}
.component-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.component-spec {
  font-size: 24rpx;
  color: #999;
}
.component-qty {
  margin-left: auto;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

/* 描述 */
.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.bottom-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.bottom-price {
  color: #ff6b81;
}
.bottom-price .price-value {
  font-size: 42rpx;
  font-weight: 700;
}
.btn-rent {
  min-width: 240rpx;
}
.btn-disabled {
  background: #ccc !important;
  color: #fff !important;
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #ff6b81;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
