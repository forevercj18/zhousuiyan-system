.info-card { padding: 28rpx; margin-bottom: 20rpx; }
.title-row { display: flex; justify-content: space-between; align-items: center; gap: 16rpx; }
.title { font-size: 32rpx; font-weight: 700; color: #333; }
.badge { font-size: 24rpx; color: #ff6b81; background: #fff0f4; padding: 6rpx 16rpx; border-radius: 999rpx; }
.tool-row { display: flex; gap: 12rpx; margin-top: 16rpx; }
.mini-btn {
  margin: 0;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #cfe2ff;
  font-size: 22rpx;
}
.section-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 14rpx; }
.sub { display: block; margin-top: 10rpx; font-size: 24rpx; color: #666; line-height: 1.6; }
.input { background: #f8f8f8; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; margin-top: 18rpx; }
.textarea { background: #f8f8f8; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; margin-top: 18rpx; min-height: 140rpx; width: 100%; box-sizing: border-box; }
.picker-field {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker-arrow { color: #999; font-size: 22rpx; }
.action-row { display: flex; gap: 16rpx; margin-top: 20rpx; }
.action-btn { flex: 1; border-radius: 999rpx; font-size: 24rpx; }
.action-btn.primary { background: #ff6b81; color: #fff; }
.action-btn.warn { background: #ffb020; color: #fff; }
.full-btn { margin-top: 20rpx; }
.loading-spinner {
  width: 48rpx; height: 48rpx; border: 4rpx solid #eee; border-top-color: #ff6b81; border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
