.search-bar {
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 32rpx;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 40rpx;
}
.search-btn {
  margin-top: 18rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
}
.result-section {
  margin-top: 20rpx;
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 0 8rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}
.section-count {
  font-size: 22rpx;
  color: #999;
}
.result-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}
.result-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}
.result-no {
  font-size: 24rpx;
  color: #999;
}
.result-status {
  font-size: 24rpx;
  color: #1677ff;
}
.result-main {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.sub-line {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
}
.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}
.meta-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff7e6;
  color: #d48806;
  font-size: 22rpx;
}
.meta-tag.blue {
  background: #e6f4ff;
  color: #1677ff;
}
.meta-tag.work {
  background: #eef5ff;
  color: #0958d9;
}
.meta-tag.danger {
  background: #fff2f0;
  color: #cf1322;
}
.tool-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.mini-btn {
  margin: 0;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #cfe2ff;
  font-size: 22rpx;
}
.mini-btn.primary {
  background: #ff6b81;
  color: #fff;
  border-color: #ff6b81;
}
.mini-btn.work {
  background: #eef5ff;
  color: #0958d9;
  border-color: #b9d4ff;
}
.mini-btn.subtle {
  color: #666;
  border-color: #e5e7eb;
}
.mini-btn.blue {
  background: #e6f4ff;
  color: #1677ff;
  border-color: #cfe2ff;
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #ff6b81;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
