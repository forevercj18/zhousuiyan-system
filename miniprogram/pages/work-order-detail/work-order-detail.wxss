.info-card { padding: 28rpx; margin-bottom: 20rpx; }
.title-row { display: flex; justify-content: space-between; gap: 16rpx; align-items: center; }
.title { font-size: 32rpx; font-weight: 700; color: #333; }
.badge { font-size: 24rpx; color: #1677ff; background: #e6f4ff; padding: 6rpx 16rpx; border-radius: 999rpx; }
.tool-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
.mini-btn {
  margin: 0;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #cfe2ff;
  font-size: 22rpx;
}
.section-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 14rpx; }
.sub { display: block; margin-top: 10rpx; font-size: 24rpx; color: #666; line-height: 1.6; }
.input { background: #f8f8f8; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; margin-top: 18rpx; }
.primary-btn { margin-top: 20rpx; background: #ff6b81; color: #fff; border-radius: 999rpx; font-size: 28rpx; }
.secondary-btn { background: #1677ff; }
.picker-field {
  margin-top: 18rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}
.loading-spinner {
  width: 48rpx; height: 48rpx; border: 4rpx solid #eee; border-top-color: #ff6b81; border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
