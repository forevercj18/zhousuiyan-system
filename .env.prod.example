DJANGO_SETTINGS_MODULE=config.settings_prod
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

DB_ENGINE=postgres
DB_NAME=zhousuiyan
DB_USER=zhousuiyan_user
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=False
SECURE_REFERRER_POLICY=same-origin

LOG_LEVEL=INFO

R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=replace-with-r2-bucket
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://pic.example.com
R2_REGION=auto
R2_UPLOAD_PREFIX_SKU=sku-images/
R2_UPLOAD_EXPIRE=900
MP_PUBLIC_BASE_URL=https://erp.example.com
